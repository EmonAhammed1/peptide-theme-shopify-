<div class="custom-hero-section" style="background-color: #080B10; color: #ffffff; padding: 80px 0; border-bottom: 1px solid #1f2937; overflow: hidden; position: relative;">
  <div class="page-width" style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; align-items: center;">
    
    <!-- Left: Content -->
    <div>
      <div style="font-family: var(--font-mono-family); font-size: 11px; font-weight: bold; color: #3cd6c4; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 15px; display: inline-flex; align-items: center; gap: 8px;">
        <span style="width: 6px; height: 6px; background-color: #3cd6c4; border-radius: 50%; display: inline-block;"></span>
        HPLC VERIFIED & COMPLIANT
      </div>
      
      <h1 style="font-family: var(--font-body-family); font-size: 56px; font-weight: 800; line-height: 1.1; margin: 0 0 25px 0; color: #ffffff; letter-spacing: -0.02em;">
        Research-Grade Peptides.<br>
        <span style="color: #3cd6c4;">Delivered Across the UAE.</span>
      </h1>
      
      <!-- Metrics Row -->
      <div style="display: flex; gap: 15px; margin-bottom: 40px; flex-wrap: wrap;">
        <div style="flex: 1; min-width: 120px; border: 1px solid #1f2937; padding: 15px; border-radius: 8px; background: rgba(255, 255, 255, 0.02); text-align: left;">
          <div style="font-family: var(--font-mono-family); font-size: 20px; font-weight: 800; color: #3cd6c4; margin-bottom: 5px;">>99%</div>
          <div style="font-size: 11px; color: #8a929e; font-family: var(--font-mono-family); text-transform: uppercase;">Purity Rate</div>
        </div>
        <div style="flex: 1; min-width: 120px; border: 1px solid #1f2937; padding: 15px; border-radius: 8px; background: rgba(255, 255, 255, 0.02); text-align: left;">
          <div style="font-family: var(--font-mono-family); font-size: 20px; font-weight: 800; color: #3cd6c4; margin-bottom: 5px;">24h</div>
          <div style="font-size: 11px; color: #8a929e; font-family: var(--font-mono-family); text-transform: uppercase;">Dispatch</div>
        </div>
        <div style="flex: 1; min-width: 120px; border: 1px solid #1f2937; padding: 15px; border-radius: 8px; background: rgba(255, 255, 255, 0.02); text-align: left;">
          <div style="font-family: var(--font-mono-family); font-size: 20px; font-weight: 800; color: #3cd6c4; margin-bottom: 5px;">UAE-Wide</div>
          <div style="font-size: 11px; color: #8a929e; font-family: var(--font-mono-family); text-transform: uppercase;">Safe Delivery</div>
        </div>
      </div>
      
      <!-- CTA Buttons -->
      <div style="display: flex; gap: 20px; flex-wrap: wrap;">
        <a href="{{ section.settings.primary_url | default: '/collections/all' }}" class="hero-btn-primary" style="background-color: #3cd6c4; color: #000000; padding: 16px 36px; border-radius: 6px; font-family: var(--font-mono-family); font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; text-decoration: none; display: inline-block; transition: all 0.3s ease; border: 1px solid #3cd6c4;">
          {{ section.settings.primary_text | default: 'SHOP NOW' }}
        </a>
        <a href="{{ section.settings.secondary_url | default: '/collections/all' }}" class="hero-btn-secondary" style="background-color: transparent; color: #ffffff; padding: 16px 36px; border-radius: 6px; font-family: var(--font-mono-family); font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; text-decoration: none; display: inline-block; transition: all 0.3s ease; border: 1px solid #1f2937;">
          {{ section.settings.secondary_text | default: 'VIEW COMPOUNDS' }}
        </a>
      </div>
    </div>
    
    <!-- Right: Featured Product Display Card -->
    <div style="position: relative; display: flex; justify-content: center;">
      <!-- Decorative radial gradient background glow -->
      <div style="position: absolute; width: 300px; height: 300px; background: radial-gradient(circle, rgba(60, 214, 196, 0.12) 0%, rgba(0,0,0,0) 70%); top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1;"></div>
      
      <!-- Glassmorphic Card Container -->
      <div class="hero-glass-card" style="position: relative; z-index: 2; width: 100%; max-width: 380px; background: rgba(10, 13, 18, 0.4); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; {% if section.settings.hero_image == blank %}padding: 16px;{% endif %} overflow: hidden; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255,255,255,0.1); transition: all 0.5s ease; display: flex; align-items: center; justify-content: center; min-height: 380px; height: 380px; box-sizing: border-box;">
        {%- if section.settings.hero_image != blank -%}
          <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
            <img src="{{ section.settings.hero_image | image_url: width: 600 }}" alt="Hero Image" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" class="hero-card-img">
          </div>
        {%- elsif section.settings.featured_product != blank -%}
          {%- assign prod = all_products[section.settings.featured_product] -%}
          {%- if prod.featured_image != blank -%}
            <a href="{{ prod.url }}" style="text-decoration: none; display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;">
              <img src="{{ prod.featured_image | image_url: width: 600 }}" alt="{{ prod.title }}" style="max-width: 100%; height: auto; max-height: 340px; object-fit: contain; filter: drop-shadow(0 15px 25px rgba(0,0,0,0.6)); transition: transform 0.5s ease;" class="hero-card-img">
            </a>
          {%- else -%}
            <div style="color: #4b5563; font-family: var(--font-mono-family); font-size: 11px;">[ PRODUCT HAS NO IMAGE ]</div>
          {%- endif -%}
        {%- else -%}
          <!-- Default placeholder design if nothing is set -->
          <div style="width: 100%; display: flex; align-items: center; justify-content: center;">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    </div>
    
  </div>
</div>

<style>
@keyframes pulse-green {
  0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(60, 214, 196, 0.7); }
  70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(60, 214, 196, 0); }
  100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(60, 214, 196, 0); }
}
.pulsing-green-dot {
  width: 6px;
  height: 6px;
  background-color: #3cd6c4;
  border-radius: 50%;
  display: inline-block;
  animation: pulse-green 2s infinite;
}
.hero-btn-primary:hover {
  background-color: transparent !important;
  color: #3cd6c4 !important;
}
.hero-btn-secondary:hover {
  border-color: #3cd6c4 !important;
  color: #3cd6c4 !important;
}
.hero-glass-card:hover {
  border-color: rgba(60, 214, 196, 0.3) !important;
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.6), 0 0 25px rgba(60, 214, 196, 0.15) !important;
}
.hero-glass-card:hover .hero-card-img {
  transform: translateY(-8px) scale(1.03);
}

@media screen and (max-width: 990px) {
  .custom-hero-section {
    padding: 60px 0 !important;
  }
  .custom-hero-section > .page-width {
    grid-template-columns: 1fr !important;
    gap: 40px !important;
    text-align: center !important;
  }
  .custom-hero-section h1 {
    font-size: 38px !important;
  }
  .custom-hero-section div[style*="display: flex"] {
    justify-content: center !important;
  }
}
</style>

{% schema %}
{
  "name": "Premium Custom Hero",
  "settings": [
    {
      "type": "text",
      "id": "primary_text",
      "label": "Primary Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary Button Text",
      "default": "VIEW COMPOUNDS"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary Button Link"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Card Product"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Custom Hero Card Image"
    }
  ],
  "presets": [
    {
      "name": "Premium Custom Hero"
    }
  ]
}
{% endschema %}
