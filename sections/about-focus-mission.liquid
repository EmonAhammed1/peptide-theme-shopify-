<div class="about-focus-mission section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; border-top: 1px solid #1f2937; border-bottom: 1px solid #1f2937;">
  <div class="page-width">
    <!-- Top Grid: Focus -->
    <div class="about-focus__grid">
      <div class="about-focus__left">
        {%- if section.settings.focus_sublabel != blank -%}
          <div class="about-section-sublabel" style="color: {{ section.settings.accent_color }};">
            — {{ section.settings.focus_sublabel | escape }}
          </div>
        {%- endif -%}
        {%- if section.settings.focus_heading != blank -%}
          <h3 class="about-focus-heading" style="color: {{ section.settings.heading_color }};">
            {{ section.settings.focus_heading }}
          </h3>
        {%- endif -%}
      </div>
      <div class="about-focus__right">
        {%- if section.settings.focus_description != blank -%}
          <div class="about-focus-description" style="color: {{ section.settings.desc_color }};">
            {{ section.settings.focus_description }}
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Bottom Box: Mission -->
    {%- if section.settings.show_mission -%}
      <div class="about-mission__box" style="background: {{ section.settings.mission_box_bg }}; border: 1px solid {{ section.settings.mission_box_border }};">
        {%- if section.settings.mission_sublabel != blank -%}
          <div class="about-section-sublabel mission-sublabel" style="color: {{ section.settings.accent_color }};">
            — {{ section.settings.mission_sublabel | escape }}
          </div>
        {%- endif -%}
        {%- if section.settings.mission_heading != blank -%}
          <h4 class="about-mission-heading" style="color: {{ section.settings.heading_color }};">
            {{ section.settings.mission_heading }}
          </h4>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .about-focus__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 48px;
    align-items: start;
  }

  @media screen and (min-width: 750px) {
    .about-focus__grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 64px;
      margin-bottom: 64px;
    }
  }

  .about-focus-heading {
    font-family: var(--font-heading-family), sans-serif;
    font-size: 28px;
    font-weight: 800;
    line-height: 1.3;
    margin: 0;
    letter-spacing: -0.01em;
  }

  @media screen and (min-width: 750px) {
    .about-focus-heading {
      font-size: 38px;
    }
  }

  .about-focus-description {
    font-family: var(--font-body-family), sans-serif;
    font-size: 15px;
    line-height: 1.7;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .about-focus-description {
      font-size: 16px;
      margin-top: 36px; /* align roughly with content */
    }
  }

  .about-mission__box {
    text-align: center;
    padding: 40px 24px;
    border-radius: 12px;
  }

  @media screen and (min-width: 750px) {
    .about-mission__box {
      padding: 60px 80px;
    }
  }

  .mission-sublabel {
    justify-content: center;
    margin-bottom: 16px;
  }

  .about-mission-heading {
    font-family: var(--font-heading-family), sans-serif;
    font-size: 22px;
    font-weight: 700;
    line-height: 1.4;
    margin: 0 auto;
    max-width: 720px;
    letter-spacing: -0.01em;
  }

  @media screen and (min-width: 750px) {
    .about-mission-heading {
      font-size: 28px;
    }
  }

  .about-mission-heading em {
    font-style: italic;
    color: {{ section.settings.accent_color }} !important;
    font-weight: inherit;
  }
</style>

{% schema %}
{
  "name": "About Focus & Mission",
  "settings": [
    {
      "type": "header",
      "content": "Focus Column Settings"
    },
    {
      "type": "text",
      "id": "focus_sublabel",
      "label": "Focus Sub-label",
      "default": "OUR FOCUS"
    },
    {
      "type": "inline_richtext",
      "id": "focus_heading",
      "label": "Focus Heading",
      "default": "Precision research, grounded in the UAE."
    },
    {
      "type": "textarea",
      "id": "focus_description",
      "label": "Focus Description",
      "default": "Our focus is precision. We exist for those who refuse to compromise in pursuit of discovery, recovery insights, and cellular-level breakthroughs — all backed by rigorous quality assurance and transparent documentation."
    },
    {
      "type": "header",
      "content": "Mission Box Settings"
    },
    {
      "type": "checkbox",
      "id": "show_mission",
      "label": "Show Mission Box",
      "default": true
    },
    {
      "type": "text",
      "id": "mission_sublabel",
      "label": "Mission Sub-label",
      "default": "OUR MISSION"
    },
    {
      "type": "inline_richtext",
      "id": "mission_heading",
      "label": "Mission Heading",
      "default": "Rigorous quality assurance and <em>transparent documentation</em> — on every order."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#080B10"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description Color",
      "default": "#8A929E"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#3CD6C4"
    },
    {
      "type": "color",
      "id": "mission_box_bg",
      "label": "Mission Box Background",
      "default": "rgba(60, 214, 196, 0.03)"
    },
    {
      "type": "color",
      "id": "mission_box_border",
      "label": "Mission Box Border",
      "default": "rgba(60, 214, 196, 0.15)"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "About Us - Focus & Mission"
    }
  ]
}
{% endschema %}
