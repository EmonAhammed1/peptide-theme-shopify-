      "label": "Link 3 Label",
      "default": "SARMs"
    },
    {
      "type": "url",
      "id": "col1_link3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "col1_link4_label",
      "label": "Link 4 Label",
      "default": "Best Sellers"
    },
    {
      "type": "url",
      "id": "col1_link4_url",
      "label": "Link 4 URL"
    },
    {
      "type": "header",
      "content": "Column 2 — Resources"
    },
    {
      "type": "text",
      "id": "col2_heading",
      "label": "Column 2 Heading",
      "default": "RESOURCES"
    },
    {
      "type": "text",
      "id": "col2_link1_label",
      "label": "Link 1 Label",
