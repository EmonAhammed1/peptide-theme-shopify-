<div class="custom-trust-section" style="background-color: {{ section.settings.bg_color }}; color: #ffffff; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; border-bottom: 1px solid #1f2937;">
  <div class="page-width">
    
    <div style="text-align: center; margin-bottom: 50px;">
      <div style="font-family: var(--font-mono-family); font-size: 11px; font-weight: bold; color: {{ section.settings.accent_color }}; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 10px;">
        {{ section.settings.label_text }}
      </div>
      <h2 style="font-family: var(--font-body-family); font-size: 36px; font-weight: 800; color: #ffffff; margin: 0;">
        {{ section.settings.heading }}
      </h2>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat({{ section.settings.columns }}, 1fr); gap: 24px;">
      
      {% for block in section.blocks %}
        {% if block.type == 'badge' %}
          <div class="trust-card" {{ block.shopify_attributes }} style="background: rgba(10, 13, 18, 0.5); border: 1px solid #1f2937; padding: 30px 24px; border-radius: 12px; transition: all 0.3s ease; text-align: left;">
            <div class="trust-icon-wrapper" style="width: 48px; height: 48px; border-radius: 8px; background: rgba(60, 214, 196, 0.1); border: 1px solid rgba(60, 214, 196, 0.2); display: flex; align-items: center; justify-content: center; margin-bottom: 24px; transition: all 0.3s ease;">
              {% case block.settings.icon %}
                {% when 'verified' %}
                  <svg style="width: 22px; height: 22px; fill: {{ section.settings.accent_color }};" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                {% when 'lab' %}
                  <svg style="width: 22px; height: 22px; fill: {{ section.settings.accent_color }};" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg>
                {% when 'shield' %}
                  <svg style="width: 22px; height: 22px; fill: {{ section.settings.accent_color }};" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
                {% when 'shipping' %}
                  <svg style="width: 22px; height: 22px; fill: {{ section.settings.accent_color }};" viewBox="0 0 24 24"><path d="M20 8H4V6h16v2zm-2-6H6v2h12V2zM4 18v-8h16v8H4zm0 2h16c1.1 0 2-.9 2-2v-8c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2z"/></svg>
                {% when 'star' %}
                  <svg style="width: 22px; height: 22px; fill: {{ section.settings.accent_color }};" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                {% when 'lock' %}
                  <svg style="width: 22px; height: 22px; fill: {{ section.settings.accent_color }};" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
                {% else %}
                  <svg style="width: 22px; height: 22px; fill: {{ section.settings.accent_color }};" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              {% endcase %}
            </div>
            <h3 style="font-family: var(--font-body-family); font-size: 16px; font-weight: 700; color: #ffffff; margin: 0 0 10px 0; text-transform: uppercase; letter-spacing: 0.05em;">{{ block.settings.title }}</h3>
            <p style="font-family: var(--font-body-family); font-size: 13px; line-height: 1.6; color: #8a929e; margin: 0;">{{ block.settings.description }}</p>
          </div>
        {% endif %}
      {% endfor %}

    </div>
  </div>
</div>

<style>
.trust-card:hover {
  border-color: {{ section.settings.accent_color }} !important;
  box-shadow: 0 10px 25px rgba(60, 214, 196, 0.05) !important;
  transform: translateY(-5px);
}
.trust-card:hover .trust-icon-wrapper {
  background: {{ section.settings.accent_color }} !important;
}
.trust-card:hover .trust-icon-wrapper svg {
  fill: #000000 !important;
}

@media screen and (max-width: 990px) {
  .custom-trust-section div[style*="grid-template-columns"] {
    grid-template-columns: 1fr 1fr !important;
  }
}
@media screen and (max-width: 576px) {
  .custom-trust-section div[style*="grid-template-columns"] {
    grid-template-columns: 1fr !important;
  }
}
</style>

{% schema %}
{
  "name": "Quality Trust Badges",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Label (above heading)",
      "default": "OUR ASSURANCE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Quality You Can Trust"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (Desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#080B10"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#3cd6c4"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "verified", "label": "Verified (Info)" },
            { "value": "lab", "label": "Lab (Plus)" },
            { "value": "shield", "label": "Shield" },
            { "value": "shipping", "label": "Shipping / Box" },
            { "value": "star", "label": "Star" },
            { "value": "lock", "label": "Lock" },
            { "value": "checkmark", "label": "Checkmark" }
          ],
          "default": "checkmark"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Badge Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Short description of this quality assurance point."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quality Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon": "verified",
            "title": "HPLC VERIFIED",
            "description": "Every compound batch undergoes third-party HPLC testing to ensure strict quality control."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "lab",
            "title": "LAB TESTED PURITY",
            "description": "Minimum purity levels of 99% guaranteed on our precision research peptides."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "shield",
            "title": "SECURE COLD CHAIN",
            "description": "Maintained under temperature-controlled storage to protect product efficacy."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "shipping",
            "title": "FAST UAE SHIPPING",
            "description": "Dispatched immediately via secure local couriers directly to your research facility."
          }
        }
      ]
    }
  ]
}
{% endschema %}
