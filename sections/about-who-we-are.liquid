<div class="about-who-we-are section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="page-width">
    <div class="about-who-we-are__content">
      {%- if section.settings.show_breadcrumbs -%}
        <div class="about-breadcrumbs" style="color: {{ section.settings.desc_color }};">
          <a href="/" style="color: {{ section.settings.desc_color }}; text-decoration: none;">HOME</a>
          <span class="about-breadcrumbs__separator">/</span>
          <span class="about-breadcrumbs__current" style="color: {{ section.settings.accent_color }};">{{ page.title | upcase }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.sublabel != blank -%}
        <div class="about-section-sublabel" style="color: {{ section.settings.accent_color }};">
          — {{ section.settings.sublabel | escape }}
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="about-section-heading" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="about-section-description" style="color: {{ section.settings.desc_color }};">
          {{ section.settings.description }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .about-who-we-are__content {
    max-width: 800px;
    margin: 0;
    text-align: left;
  }

  .about-breadcrumbs {
    font-family: var(--font-mono-family), monospace;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .about-breadcrumbs a:hover {
    color: {{ section.settings.accent_color }} !important;
  }

  .about-breadcrumbs__separator {
    opacity: 0.4;
  }

  .about-section-sublabel {
    font-family: var(--font-mono-family), monospace;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 24px;
  }

  .about-section-heading {
    font-family: var(--font-heading-family), sans-serif;
    font-size: 32px;
    font-weight: 800;
    line-height: 1.25;
    margin: 0 0 24px 0;
    letter-spacing: -0.02em;
  }

  @media screen and (min-width: 750px) {
    .about-section-heading {
      font-size: 48px;
    }
  }

  .about-section-heading em {
    font-style: italic;
    color: {{ section.settings.accent_color }} !important;
    font-weight: inherit;
  }

  .about-section-description {
    font-family: var(--font-body-family), sans-serif;
    font-size: 15px;
    line-height: 1.7;
    font-weight: 400;
  }

  @media screen and (min-width: 750px) {
    .about-section-description {
      font-size: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "About Us - Who We Are",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show Breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "sublabel",
      "label": "Sub-label",
      "default": "WHO WE ARE"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "The UAE's trusted source for <em>advanced research</em>."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Odyssey Peptide is the UAE's trusted source for advanced research peptides and bio-innovation compounds. We empower scientists, researchers, and institutions to push the boundaries of biological understanding with a curated selection of high purity molecules — crafted exclusively for laboratory and experimental use.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#080B10"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description Color",
      "default": "#8A929E"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#3CD6C4"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "About Us - Who We Are"
    }
  ]
}
{% endschema %}
